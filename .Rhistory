corp_DOD$year >= 2009 & corp_DOD$year <= 2016  ~ "Obama",
corp_DOD$year >= 2017 & corp_DOD$year <= 2020  ~ "Trump",
corp_DOD$year >= 2021 & corp_DOD$year <= 2024  ~ "Biden",
corp_DOD$year >= 2025                          ~ "Trump II",
